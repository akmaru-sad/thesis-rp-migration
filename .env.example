# Copy to .env and fill. NEVER commit the populated .env.

# =============================================================================
# DATA ROOT — bulky data outside the repo
# =============================================================================
# Absolute path inside WSL2; create with:  mkdir -p ~/thesis-data
DATA_ROOT=/home/CHANGE_ME/thesis-data

# =============================================================================
# Observed data file paths (relative to DATA_ROOT)
# =============================================================================
# BWDB SW46.9L Bahadurabad Transit MDD + 3-hourly WL Excel file
BWDB_PATH=observed/bwdb_sw46p9l_bahadurabad_1988-2026.xlsx

# BWDB SW267 Surma at Sylhet (fallback)
BWDB_FALLBACK_PATH=observed/bwdb_sw267_sylhet_1988-2026.xlsx

# BMD daily rainfall national network (raw archive directory)
BMD_PATH=observed/bmd_daily_p_national/

# =============================================================================
# GEE — interactive personal account auth per D-A1-2
# =============================================================================
# After running `earthengine authenticate`, credentials are at:
#   ~/.config/earthengine/credentials
# You only need the project ID here:
GEE_PROJECT_ID=CHANGE_ME-gee-project

# =============================================================================
# Copernicus CDS — for ERA5 basin-mean acquisition (Chain B.0b)
# =============================================================================
# Register at https://cds.climate.copernicus.eu/user
CDS_API_UID=CHANGE_ME
CDS_API_KEY=CHANGE_ME

# =============================================================================
# CMIP6 / ESGF — node selection (optional)
# =============================================================================
# Primary ESGF index node; fall back to others if unavailable
ESGF_INDEX_NODE=esgf-node.llnl.gov

# =============================================================================
# Station metadata (locked per §5)
# =============================================================================
STATION_ID=SW46.9L
STATION_NAME=Bahadurabad_Transit
STATION_LAT=25.1303
STATION_LON=89.7346
RIVER=Brahmaputra-Jamuna
DRAINAGE_AREA_KM2=536000
